{
  "name": "@axionvera/core",
  "version": "1.0.0",
  "description": "Core SDK for interacting with Axionvera smart contracts on Stellar (Soroban).",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./vault": {
      "import": {
        "types": "./dist/vault.d.mts",
        "default": "./dist/vault.mjs"
      },
      "require": {
        "types": "./dist/vault.d.ts",
        "default": "./dist/vault.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      },
      "require": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils.d.mts",
        "default": "./dist/utils.mjs"
      },
      "require": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.js"
      }
    },
    "./wallet": {
      "import": {
        "types": "./dist/wallet.d.mts",
        "default": "./dist/wallet.mjs"
      },
      "require": {
        "types": "./dist/wallet.d.ts",
        "default": "./dist/wallet.js"
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npx tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node ../../node_modules/eslint/bin/eslint.js src/**/*.ts"
  },
  "sideEffects": false,
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1",
    "axios": "^1.7.9",
    "valibot": "^1.3.1"
  },
  "peerDependencies": {
    "@stellar/freighter-api": "^6.0.1"
  },
  "peerDependenciesMeta": {
    "@stellar/freighter-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "benchmark": "^2.1.4",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^1.3.5",
    "rimraf": "^6.0.1",
    "size-limit": "^11.1.6",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.6",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
